+    addHelpInformationEditor(editframe, container)
+
+    spacer = UI:Create("Spacer")
+    spacer:SetHeight(8)
+    container:AddChild(spacer)
+
+    addAuthorEditor(editframe, container)
+    addHelpLinkEditor(editframe, container)
