+local function queueCurrentSpellIconRefresh(immediate)
+    if immediate then
+        spellIconRefreshQueued = false
+        refreshCurrentSpellIconsNow()
+        return
+    end
+
+    if spellIconRefreshQueued then return end
+    spellIconRefreshQueued = true
+    GSE.After(0.05, function()
+        spellIconRefreshQueued = false
+        refreshCurrentSpellIconsNow()
+    end)
+end
