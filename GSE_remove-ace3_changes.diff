+local GSE_MODERN_CLASS_COLORS = {
+    DEATHKNIGHT = {0.77, 0.12, 0.23, 1},
+    DEMONHUNTER = {0.64, 0.19, 0.79, 1},
+    DRUID = {1.00, 0.49, 0.04, 1},
+    EVOKER = {0.20, 0.58, 0.50, 1},
+    HUNTER = {0.67, 0.83, 0.45, 1},
