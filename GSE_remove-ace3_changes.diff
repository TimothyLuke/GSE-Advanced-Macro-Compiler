+local spellIconRefreshQueued = false
+local function refreshCurrentSpellIconsNow()
+    if GSE.SequencesExec then
+        for name, _ in pairs(GSE.SequencesExec) do
+            local button = _G[name]
+            if button and GSE.UpdateIcon then
