+local function ApplySearchFilter(scrollToTop)
+    RebuildVisibleRows()
+    if scrollToTop and scrollFrame and scrollFrame.SetVerticalScroll then scrollFrame:SetVerticalScroll(0) end
+    UpdateRows(false)
