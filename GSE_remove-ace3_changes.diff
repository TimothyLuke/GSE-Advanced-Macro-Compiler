+                    if not v.MetaData then
+                        v.MetaData = {}
+                    end
+                    if not v.MetaData.GSEVersion or v.MetaData.GSEVersion < math.floor(GSE.VersionNumber/ 100) * 100 then
+                        v.MetaData.Disabled = true
