+    local labelHeight = widget.label:GetStringHeight()
+    if not labelHeight or labelHeight <= 0 then labelHeight = 12 end
+    local g = gap or (UI.NativeStyle and UI.NativeStyle.labelBoxGap) or 2
+    widget.editBox:ClearAllPoints()
