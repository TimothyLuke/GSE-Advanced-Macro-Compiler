+local function sortedKeys(list, order)
+    if order then return order end
+    local keys = {}
+    for key in pairs(list or {}) do table.insert(keys, key) end
+    table.sort(keys, function(a, b) return tostring(a) < tostring(b) end)
+    return keys
+end
