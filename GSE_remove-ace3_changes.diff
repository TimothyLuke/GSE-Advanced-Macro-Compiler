+    end
+    if width <= 0 and editframe then
+        local treeWidth = editframe.treeContainer and editframe.treeContainer.GetTreeWidth and editframe.treeContainer:GetTreeWidth() or 0
+        width = (editframe.Width or 700) - treeWidth - 72
