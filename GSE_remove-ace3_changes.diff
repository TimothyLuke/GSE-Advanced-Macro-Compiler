+function GSE.ShowDeveloperDebugActiveWarning()
+    if not GSE.HasDeveloperDebugWarning() then return end
+    GSE.GUICall("GUIShowDeveloperDebugWarning", table.concat(GSE.GetDeveloperDebugWarningReasons(), ", "))
