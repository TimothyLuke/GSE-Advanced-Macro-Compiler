+                if editframe._selectedMacroBlockBlinkToken ~= blinkToken then return end
+                if selectedOverlay.SetAlpha then selectedOverlay:SetAlpha(alpha) end
+                if selectedOverlay.Show then selectedOverlay:Show() end
+            end
